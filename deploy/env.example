# Copy to <repo-root>/.env on the server (`cp deploy/env.example .env`).
# .env is gitignored — never commit it.

# --- required ---
ANTHROPIC_API_KEY=sk-ant-...
RECONOPS_DOMAIN=recon.example.com   # leave empty for local HTTP-only runs

# --- auth (required for sign-in emails) ---
# Any transactional SMTP provider works; Resend/Postmark free tiers suffice.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=recon@example.com

# --- optional ---
SENTRY_DSN=
ANTHROPIC_MODEL=
ANTHROPIC_ROW_MODEL=claude-haiku-4-5
RECONOPS_MAX_LLM_ROWS=25
RECONOPS_CORS_ORIGINS=
RECONOPS_ENV=production
# Pin the HMAC secret for export tokens (else auto-generated on the data volume)
RECONOPS_SECRET=
