# RECONOPS_DOMAIN=recon.example.com -> automatic HTTPS via Let's Encrypt.
# Compose defaults it to ":80" (plain HTTP) when unset — an empty value here
# would make Caddy parse this block as global options, so the fallback must
# live in docker-compose.prod.yml, not in this placeholder.
{$RECONOPS_DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
