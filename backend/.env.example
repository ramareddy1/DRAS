# Anthropic API key — required for reconciliation (insights + advisory review).
ANTHROPIC_API_KEY=your-key-here

# Optional: override the model used for the insights summary
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cheaper model for the batched row-level second-opinion pass
ANTHROPIC_ROW_MODEL=claude-haiku-4-5

# Max discrepancy rows sent for AI second-opinion per job (0 disables the pass)
RECONOPS_MAX_LLM_ROWS=25
