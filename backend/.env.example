# Anthropic API key — required for reconciliation (insights + advisory review).
ANTHROPIC_API_KEY=your-key-here

# Optional: override the model used for the insights summary
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cheaper model for the batched row-level second-opinion pass
ANTHROPIC_ROW_MODEL=claude-haiku-4-5

# Max discrepancy rows sent for AI second-opinion per job (0 disables the pass)
RECONOPS_MAX_LLM_ROWS=25

# Optional: Sentry DSN for error tracking (empty = disabled)
SENTRY_DSN=

# --- auth ---
# Dev only: return the sign-in code in the API response instead of emailing.
# NEVER set in production. Local dev: set to 1 so you can sign in without SMTP.
RECONOPS_AUTH_DEV=
# SMTP for sign-in codes (any transactional provider: Resend, Postmark, SES...)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Optional: pin the HMAC secret for export tokens (else auto-generated on disk)
RECONOPS_SECRET=
